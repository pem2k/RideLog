# Copy this file to ".env" (in the same folder) and fill in real values.
# ".env" is listed in .gitignore, so it doesn't get committed.

# Your MongoDB connection string (MongoDB Atlas or local mongod).
# Example Atlas format:
# mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority

MONGO_URI=mongodb://localhost:27017

# Name of the database inside that MongoDB connection to use.
MONGO_DB_NAME=ridelog

# A random long string used to sign session cookies.
# Any long random text works - it just needs to stay secret.
SESSION_SECRET=change-this-to-a-random-string

# Port the backend server listens on.
PORT=3000